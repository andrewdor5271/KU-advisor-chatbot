@page
@using MainApp.Models
@model MainApp.Pages.Elements.Index.MessagesPageModel
@{
    Layout = null;
}
<!--ATTENTION. REVERSE ORDER due to column-reverse in index.cshtml-->


<div class="msg-inbox">
    <div class="msg-page"
         id="msg-page">
        @foreach (var message in Model.Messages)
        {
            @if (message.SenderType == SenderType.User)
            {
                <div class="message sent">
                    <div class="msg-text">
                        <p>
                            @message.Text
                        </p>
                        <span class="time">@message.CreationDatetime </span>
                    </div>
                </div>
            }
            else
            {
                <div class="message received">
                    <div class="msg-text">
                        <p>
                            @message.Text
                        </p>
                        <span class="time">@message.CreationDatetime </span>
                    </div>
                </div>
            }
        }

        @if (Model.Messages.Count() >= Consts.MESSAGE_BATCH_SIZE)
        {
            <div hx-get="/Elements/Index/_Messages?ConversationId=@Model.ConversationId&PreviousMessageId=@Model.LastLoadedMessageId"
                 hx-trigger="intersect once"
                 hx-swap="outerHTML">
                Loading...
            </div>
        }
    </div>

</div>

<form class="new-msg-input"
      hx-post="/Elements/Index/_NewMessage"
      hx-target="#msg-page"
      hx-swap="afterbegin"
      hx-on::after-request="this.reset()"
      hx-vals='{"ConversationId":@Model.ConversationId}'>
    @Html.AntiForgeryToken()
    <input name="Text" type="text" class="form-control" placeholder="Write message...">
    <span class="input-group-text">
        <button class="bi bi-send"></button>
    </span>
</form>