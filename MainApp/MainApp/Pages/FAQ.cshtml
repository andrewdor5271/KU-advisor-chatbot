@page
@model MainApp.Pages.FAQModel
@{
    ViewData["Title"] = "FAQ";
}

<div class="layout-spacer">
    <div id="sidebar" class="sidebar">
        <partial name="/Pages/Elements/GlobalPartials/_SidebarHeaderPartial.cshtml" />
    </div>
    <div class="faq-page">
        <div class="faq-toolbar">
            <div>
                <h1 class="faq-title">Frequently Asked</h1>
                <p class="faq-subtitle">Saved advisor conversations, searchable by topic and message text.</p>
            </div>
            <form class="faq-search"
                  hx-get="/Elements/FAQ/FAQConversations"
                  hx-target="#faq-content"
                  hx-trigger="submit, keyup changed delay:300ms from:#faq-search-input">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="faq-search-input"
                           name="search"
                           class="form-control"
                           type="search"
                           placeholder="Search FAQ chats"
                           aria-label="Search FAQ chats">
                </div>
            </form>
        </div>

        <div id="faq-content"
             class="faq-content"
             hx-get="/Elements/FAQ/FAQConversations"
             hx-trigger="load">
        </div>
    </div>
</div>
