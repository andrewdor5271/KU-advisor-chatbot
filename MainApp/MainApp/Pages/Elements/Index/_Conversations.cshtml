@page
@model MainApp.Pages.Elements.Index.ConversationsPageModel
@{
    Layout = null;
}

@if (Model.Conversations.Count == 0)
{
    <!-- Dummy convo for future creation - just an empty message page -->
    <div class="conversation-button"
         id="Conv_0"
         hx-get="/Elements/Index/_Messages"
         hx-target="#chatbox-container"
         hx-trigger="click">
        @Consts.DUMMY_CONVO_DEFAULT_TITLE
    </div>
}
else
{
    @for (int i = 0; i < Model.Conversations.Count; i++)
    {
        <div class="conversation-button"
             id="Conv_@i"
             hx-get="/Elements/Index/_Messages?ConversationId=@Model.Conversations[i].ConversationId"
             hx-target="#chatbox-container"
             hx-trigger="click">
            @Model.Conversations[i].Title
        </div>
    }
}


